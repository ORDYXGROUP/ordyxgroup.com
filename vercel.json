{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ordyx.de" }],
      "destination": "https://www.ordyxgroup.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.ordyx.de" }],
      "destination": "https://www.ordyxgroup.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ordyxgroup.com" }],
      "destination": "https://www.ordyxgroup.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
